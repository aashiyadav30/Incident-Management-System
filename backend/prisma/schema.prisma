// Prisma Schema — Incident Management System
// PostgreSQL stores structured, relational, transactional data only.
// Raw signals live in MongoDB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Severity {
  P0 // Critical — total outage, data loss risk
  P1 // High     — major feature broken
  P2 // Moderate — degraded performance
}

enum IncidentStatus {
  OPEN          // Auto-created when first signal arrives
  INVESTIGATING // Engineer has acknowledged
  RESOLVED      // Fix applied, monitoring
  CLOSED        // RCA submitted, fully done
}

// ─── Incident ─────────────────────────────────────────────────────────────────

model Incident {
  id           String         @id @default(uuid())
  component_id String         // e.g. "CACHE_CLUSTER_01"
  severity     Severity
  status       IncidentStatus @default(OPEN)
  title        String         // Human-readable summary derived from first signal

  // Lifecycle timestamps — used for MTTR calculation
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  resolved_at  DateTime?      // Set when status → RESOLVED
  closed_at    DateTime?      // Set when status → CLOSED

  // MTTR in seconds: closed_at - created_at
  // Stored denormalized for fast dashboard queries
  mttr_seconds Int?

  // Array of MongoDB ObjectId strings for linked raw signals
  // We store references, not the signal data itself — keep stores separate
  signal_ids   String[]       @default([])

  // One-to-one RCA (only exists after RESOLVED → CLOSED transition)
  rca          RCA?

  // Index on component_id + status for fast "active incidents per component" queries
  @@index([component_id, status])
  // Index for dashboard sorting by severity + created time
  @@index([severity, created_at])
}

// ─── RCA (Root Cause Analysis) ────────────────────────────────────────────────

model RCA {
  id                String   @id @default(uuid())

  // One-to-one with Incident — RCA cannot exist without an incident
  incident_id       String   @unique
  incident          Incident @relation(fields: [incident_id], references: [id], onDelete: Cascade)

  root_cause        String   // Category: e.g. "Misconfiguration", "Traffic spike"
  fix_applied       String   // What was done to resolve
  prevention_steps  String   // What prevents recurrence

  // These may differ from incident created_at/resolved_at —
  // the engineer may report the actual impact window
  impact_start_time DateTime
  impact_end_time   DateTime

  submitted_at      DateTime @default(now())
  submitted_by      String?  // Optional: engineer name/id
}